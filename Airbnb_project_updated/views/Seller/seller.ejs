<%- include('../partial/head')%>
<%- include('../partial/nav_s')%>


    <!-- Form Container -->
    <div class="container">
        <div class="card">
            <h1>Register Your Home on AirBnB</h1>

            <form action="<%= val? /seller/edit : /seller/home %>" method="post">
                <input type="text" placeholder="House Name"  name="HouseName" required autofocus>

                <input type="number" placeholder="Price Per Night" name="price" required>

                <input type="text" placeholder="Location" name="location" required>

                <input type="number" step="0.1" min="1" max="5" placeholder="Rating" name="rate" required>

                <input type="url" placeholder="Enter Photo URL"  name="url" required>

                <button type="submit">Submit</button>
            </form>
        </div>
    </div>

</body>
</html>