<%- include('../partial/head') %>
<%- include('../partial/nav') %>

<div class="container">
    <div class="card">

        <h1>Here are our Registered Homes</h1> 
        <div class="fav"><a href="/fav" style="color: white; font-size: 25px;">♡</a></div>
        <% home.forEach(house => { %>

            <div class="home">

                <img src="<%= house.photoUrl %>" alt="Home Image" width="300">

                <h2><%= house.houseName %></h2>

                <p><strong>Location:</strong> <%= house.location %></p>

                <p><strong>Price:</strong> ₹<%= house.price %> / night</p>

                <p><strong>Rating:</strong> ⭐ <%= house.rating %></p>

                <hr>
                <div class="button">
                    <div class="t1">Book</div>
                </div>
            </div>

        <% }) %>

    </div>
</div>

</body>
</html>